#!/bin/sh

# 1. Mount virtual filesystems (proc, sys, dev)
# Linux processes and utilities require /proc, /sys, and /dev to interact with the kernel and hardware.
# - /proc: Contains process information and kernel state (e.g. cpuinfo, meminfo).
# - /sys: Allows configuring kernel parameters and hardware devices.
# - /dev: Contains device nodes (e.g. disk devices, console interfaces).
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev 2>/dev/null || mount -t tmpfs none /dev

# 2. Setup pseudo-terminals (devpts)
mkdir -p /dev/pts
mount -t devpts none /dev/pts

# 3. Load Network Driver Modules
echo "[-] Loading network driver modules..."
if [ -d /lib/modules ]; then
    # load virtio_net dependencies
    if [ -f /lib/modules/failover.ko ]; then
        echo "    Loading failover..."
        insmod /lib/modules/failover.ko
    fi
    if [ -f /lib/modules/net_failover.ko ]; then
        echo "    Loading net_failover..."
        insmod /lib/modules/net_failover.ko
    fi
    # load drivers
    if [ -f /lib/modules/virtio_net.ko ]; then
        echo "    Loading virtio_net..."
        insmod /lib/modules/virtio_net.ko
    fi
    if [ -f /lib/modules/e1000.ko ]; then
        echo "    Loading e1000..."
        insmod /lib/modules/e1000.ko
    fi
else
    echo "[!] /lib/modules directory not found!"
fi

# 4. Setup Network Interfaces
# - Bring up the loopback interface (needed for local loopback connections).
# - Scan /sys/class/net/ to find the first physical ethernet card and request IP via DHCP in background.
echo "[-] Initializing network loopback..."
ifconfig lo 127.0.0.1 up

NET_INT=""
for dev in /sys/class/net/*; do
    name=$(basename "$dev")
    if [ "$name" != "lo" ] && [ "$name" != "*" ]; then
        NET_INT="$name"
        break
    fi
done

if [ -n "$NET_INT" ]; then
    echo "[+] Found network interface: $NET_INT"
    echo "[-] Requesting IP address via DHCP in the background..."
    # -i: interface, -s: configuration script, -b: run in background if no lease immediately
    udhcpc -i "$NET_INT" -s /etc/udhcpc.script -b &
else
    echo "[!] No network interface card detected."
fi

# 5. Define multi-console shell spawner
run_shell() {
    tty_dev="$1"
    if [ -c "$tty_dev" ]; then
        while true; do
            # Display welcome message on this specific terminal
            echo "" > "$tty_dev"
            if [ -f /welcome.txt ]; then
                cat /welcome.txt > "$tty_dev"
            else
                echo "Welcome to FATEOS!" > "$tty_dev"
            fi
            echo "" > "$tty_dev"
            echo "=======================================================" > "$tty_dev"
            echo "  D5BU-FateOS V1 (Ultra-Lightweight Edition)          " > "$tty_dev"
            echo "  Kernel: $(uname -r)                                 " > "$tty_dev"
            echo "  Terminal: $(basename "$tty_dev")                    " > "$tty_dev"
            echo "=======================================================" > "$tty_dev"
            echo "" > "$tty_dev"
            echo "Explore the system using BusyBox commands!" > "$tty_dev"
            echo "Type 'poweroff -f' to shut down the virtual machine safely." > "$tty_dev"
            echo "" > "$tty_dev"
            
            # Spawn interactive shell with job control (Ctrl+C)
            setsid sh -c "exec sh <$tty_dev >$tty_dev 2>&1"
            echo "Shell on $tty_dev exited. Restarting in 1 second..." > "$tty_dev"
            sleep 1
        done
    fi
}

# 6. Spawn interactive BusyBox shells on both VGA and Serial consoles
echo "[-] Spawning interactive shell on VGA console (/dev/tty1)..."
run_shell /dev/tty1 &

echo "[-] Spawning interactive shell on serial console (/dev/ttyS0)..."
run_shell /dev/ttyS0 &

# Wait for background shell processes to keep init (PID 1) alive
wait
